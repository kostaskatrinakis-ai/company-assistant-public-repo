generator client {
  provider   = "prisma-client-js"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  OWNER
  OPERATOR
  TECHNICIAN
}

enum PreferredChannel {
  APP
  WHATSAPP
  MOBILE
}

enum RequestSourceChannel {
  PHONE
  WHATSAPP
  APP
  MANUAL
}

enum RequestPriority {
  URGENT
  TODAY
  PLANNED
}

enum RequestState {
  NEW
  AWAITING_DETAILS
  READY_TO_SCHEDULE
  SCHEDULED
  CANCELED
  CONVERTED
}

enum AppointmentState {
  DRAFT
  SCHEDULED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  MISSED
  RESCHEDULED
  CANCELED
}

enum WorkOrderState {
  DRAFT
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  FOLLOW_UP_REQUIRED
  READY_FOR_INVOICE
  CANCELED
}

enum WorkOrderAssignmentState {
  ACTIVE
  COMPLETED
  REMOVED
}

enum InvoiceReminderState {
  PENDING
  QUEUED_FOR_MONTH
  READY_FOR_ACCOUNTING
  CLEARED
  CANCELED
}

enum AssistantChannel {
  APP
  WHATSAPP
  IMESSAGE
}

enum AssistantContextType {
  GLOBAL
  REQUEST
  WORK_ORDER
  DASHBOARD
}

enum AssistantConversationStatus {
  OPEN
  CLOSED
  BLOCKED
}

enum MessagingChannel {
  WHATSAPP
  IMESSAGE
}

enum ChannelIdentityStatus {
  VERIFIED
  REVOKED
  BLOCKED
}

enum ChannelPairingSessionStatus {
  PENDING
  CONSUMED
  REVOKED
  EXPIRED
}

enum HeartbeatCadenceUnit {
  MINUTES
  HOURS
  DAYS
}

enum HeartbeatRunStatus {
  IDLE
  SUCCESS
  FAILED
}

enum AssistantSenderType {
  USER
  ASSISTANT
  SYSTEM
}

enum AssistantActionOutcome {
  SUCCESS
  REJECTED
  FAILED
  NOOP
}

enum AssistantActionRequestStatus {
  PENDING
  APPROVED
  REJECTED
  EXECUTED
  FAILED
}

enum DomainEntityType {
  CUSTOMER
  LOCATION
  EQUIPMENT
  REQUEST
  APPOINTMENT
  WORK_ORDER
  REMINDER
  ASSISTANT_CONVERSATION
  MANUAL_ACTION
  UNKNOWN
}

enum WhatsAppDirection {
  INCOMING
  OUTGOING
}

enum WhatsAppDetectedActorType {
  INTERNAL_USER
  CUSTOMER
  UNKNOWN
}

enum WhatsAppProcessedStatus {
  PENDING
  LINKED
  AMBIGUOUS
  FAILED
  IGNORED
}

enum ManualActionType {
  APPOINTMENT
  FOLLOW_UP
  CALLBACK
  INTERNAL_NOTE
  REMINDER
}

enum ManualActionStatus {
  OPEN
  IN_PROGRESS
  DONE
  CANCELED
}

enum AuditActorSource {
  APP
  WHATSAPP
  JOB
  SYSTEM
}

model User {
  id                     String                  @id @default(cuid())
  auth0UserId            String?                 @unique
  email                  String                  @unique
  fullName               String
  role                   UserRole
  isActive               Boolean                 @default(true)
  deletedAt              DateTime?
  passwordHash           String?
  phoneNumber            String?                 @unique
  preferredChannel       PreferredChannel        @default(APP)
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  createdRequests        Request[]               @relation("RequestCreator")
  assignedAppointments   Appointment[]           @relation("AppointmentAssignee")
  createdAppointments    Appointment[]           @relation("AppointmentCreator")
  updatedAppointments    Appointment[]           @relation("AppointmentUpdater")
  createdWorkOrders      WorkOrder[]             @relation("WorkOrderCreator")
  closedWorkOrders       WorkOrder[]             @relation("WorkOrderCloser")
  assignments            WorkOrderAssignment[]
  timeEntries            TimeEntry[]
  createdMaterials       MaterialUsage[]         @relation("MaterialCreator")
  createdReminders       InvoiceReminder[]       @relation("ReminderCreator")
  updatedReminders       InvoiceReminder[]       @relation("ReminderUpdater")
  createdCustomers       Customer[]              @relation("CustomerCreator")
  createdLocations       Location[]              @relation("LocationCreator")
  assistantConversations AssistantConversation[]
  assistantActions       AssistantActionLog[]
  assistantActionRequests AssistantActionRequest[]
  createdManualActions   ManualAction[]          @relation("ManualActionCreator")
  assignedManualActions  ManualAction[]          @relation("ManualActionAssignee")
  auditLogs              AuditLog[]              @relation("AuditActor")
  channelIdentities      UserChannelIdentity[]
  channelPairingSessions ChannelPairingSession[]
  linkedWhatsAppMessages WhatsAppMessage[]       @relation("WhatsAppMessageLinkedUser")
  heartbeatUpdatedConfigs HeartbeatConfig[]      @relation("HeartbeatConfigUpdater")
  heartbeatNotifications HeartbeatNotification[] @relation("HeartbeatNotificationRecipient")

  @@index([role, isActive])
}

model Customer {
  id                        String            @id @default(cuid())
  businessName              String
  vatNumber                 String?
  mainPhone                 String?
  mainEmail                 String?
  notes                     String?
  createdByUserId           String?
  createdByUserNameSnapshot String?
  createdAt                 DateTime          @default(now())
  updatedAt                 DateTime          @updatedAt
  createdBy                 User?             @relation("CustomerCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  locations                 Location[]
  requests                  Request[]
  invoiceReminders          InvoiceReminder[]
  workOrders                WorkOrder[]

  @@index([businessName])
}

model Location {
  id                        String      @id @default(cuid())
  customerId                String
  name                      String
  address                   String
  city                      String?
  notes                     String?
  createdByUserId           String?
  createdByUserNameSnapshot String?
  createdAt                 DateTime    @default(now())
  updatedAt                 DateTime    @updatedAt
  customer                  Customer    @relation(fields: [customerId], references: [id], onDelete: Restrict)
  createdBy                 User?       @relation("LocationCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  equipment                 Equipment[]
  requests                  Request[]
  workOrders                WorkOrder[]

  @@index([customerId])
}

model Equipment {
  id            String   @id @default(cuid())
  locationId    String
  label         String
  equipmentType String?
  serialNumber  String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  location      Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@index([locationId])
}

model Request {
  id                        String               @id @default(cuid())
  customerId                String?
  locationId                String?
  sourceChannel             RequestSourceChannel
  description               String
  priority                  RequestPriority
  state                     RequestState         @default(NEW)
  reportedByName            String?
  createdByUserId           String
  createdByUserNameSnapshot String?
  createdAt                 DateTime             @default(now())
  updatedAt                 DateTime             @updatedAt
  customer                  Customer?            @relation(fields: [customerId], references: [id], onDelete: SetNull)
  location                  Location?            @relation(fields: [locationId], references: [id], onDelete: SetNull)
  createdBy                 User                 @relation("RequestCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  appointments              Appointment[]
  workOrders                WorkOrder[]

  @@index([customerId, locationId, state])
}

model Appointment {
  id                        String           @id @default(cuid())
  requestId                 String?
  workOrderId               String?
  assignedUserId            String
  startAt                   DateTime
  endAt                     DateTime?
  state                     AppointmentState @default(DRAFT)
  reasonNote                String?
  createdByUserId           String
  createdByUserNameSnapshot String?
  updatedByUserId           String?
  updatedByUserNameSnapshot String?
  createdAt                 DateTime         @default(now())
  updatedAt                 DateTime         @updatedAt
  request                   Request?         @relation(fields: [requestId], references: [id], onDelete: SetNull)
  workOrder                 WorkOrder?       @relation(fields: [workOrderId], references: [id], onDelete: SetNull)
  assignedUser              User             @relation("AppointmentAssignee", fields: [assignedUserId], references: [id], onDelete: Restrict)
  createdBy                 User             @relation("AppointmentCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  updatedBy                 User?            @relation("AppointmentUpdater", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@index([assignedUserId, state, startAt])
  @@index([requestId])
  @@index([workOrderId])
}

model WorkOrder {
  id                        String                     @id @default(cuid())
  requestId                 String?
  customerId                String
  locationId                String
  state                     WorkOrderState             @default(DRAFT)
  issueSummary              String
  resolutionSummary         String?
  followUpReason            String?
  invoiceReadyAt            DateTime?
  createdByUserId           String
  createdByUserNameSnapshot String?
  closedByUserId            String?
  closedByUserNameSnapshot  String?
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
  request                   Request?                   @relation(fields: [requestId], references: [id], onDelete: SetNull)
  customer                  Customer                   @relation(fields: [customerId], references: [id], onDelete: Restrict)
  location                  Location                   @relation(fields: [locationId], references: [id], onDelete: Restrict)
  createdBy                 User                       @relation("WorkOrderCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  closedBy                  User?                      @relation("WorkOrderCloser", fields: [closedByUserId], references: [id], onDelete: SetNull)
  assignments               WorkOrderAssignment[]
  timeEntries               TimeEntry[]
  materialUsages            MaterialUsage[]
  appointments              Appointment[]
  manualActions             ManualAction[]
  assistantActions          AssistantActionLog[]
  reminderLinks             InvoiceReminderWorkOrder[]

  @@index([customerId, locationId, state])
  @@index([requestId])
}

model WorkOrderAssignment {
  id          String                   @id @default(cuid())
  workOrderId String
  userId      String
  state       WorkOrderAssignmentState @default(ACTIVE)
  isPrimary   Boolean                  @default(true)
  assignedAt  DateTime                 @default(now())
  releasedAt  DateTime?
  workOrder   WorkOrder                @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  user        User                     @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([workOrderId, state])
  @@index([userId, state])
}

model TimeEntry {
  id            String    @id @default(cuid())
  workOrderId   String
  userId        String
  minutesWorked Int       @default(0)
  minutesTravel Int       @default(0)
  note          String?
  createdAt     DateTime  @default(now())
  workOrder     WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  user          User      @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([workOrderId, userId])
}

model MaterialUsage {
  id              String    @id @default(cuid())
  workOrderId     String
  description     String
  quantity        Decimal   @db.Decimal(10, 2)
  unit            String
  estimatedCost   Decimal?  @db.Decimal(10, 2)
  createdByUserId String
  createdAt       DateTime  @default(now())
  workOrder       WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  createdBy       User      @relation("MaterialCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@index([workOrderId])
}

model InvoiceReminder {
  id                        String                     @id @default(cuid())
  customerId                String
  monthKey                  String
  state                     InvoiceReminderState       @default(PENDING)
  estimatedTotal            Decimal                    @db.Decimal(10, 2)
  note                      String?
  createdByUserId           String
  createdByUserNameSnapshot String?
  updatedByUserId           String?
  updatedByUserNameSnapshot String?
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
  customer                  Customer                   @relation(fields: [customerId], references: [id], onDelete: Restrict)
  createdBy                 User                       @relation("ReminderCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  updatedBy                 User?                      @relation("ReminderUpdater", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  workOrders                InvoiceReminderWorkOrder[]

  @@unique([customerId, monthKey])
  @@index([state, monthKey])
}

model InvoiceReminderWorkOrder {
  invoiceReminderId String
  workOrderId       String
  linkedAt          DateTime        @default(now())
  invoiceReminder   InvoiceReminder @relation(fields: [invoiceReminderId], references: [id], onDelete: Cascade)
  workOrder         WorkOrder       @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@id([invoiceReminderId, workOrderId])
  @@index([workOrderId])
}

model AssistantConversation {
  id              String                      @id @default(cuid())
  userId          String
  channel         AssistantChannel
  contextType     AssistantContextType
  contextEntityId String?
  status          AssistantConversationStatus @default(OPEN)
  createdAt       DateTime                    @default(now())
  updatedAt       DateTime                    @updatedAt
  user            User                        @relation(fields: [userId], references: [id], onDelete: Restrict)
  messages        AssistantMessage[]
  actions         AssistantActionLog[]
  actionRequests  AssistantActionRequest[]

  @@index([userId, status])
  @@index([contextType, contextEntityId])
}

model AssistantMessage {
  id                String                @id @default(cuid())
  conversationId    String
  senderType        AssistantSenderType
  body              String
  providerMessageId String?
  createdAt         DateTime              @default(now())
  conversation      AssistantConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model AssistantActionLog {
  id               String                 @id @default(cuid())
  conversationId   String
  userId           String
  actionName       String
  targetEntityType DomainEntityType
  targetEntityId   String?
  outcome          AssistantActionOutcome
  createdAt        DateTime               @default(now())
  conversation     AssistantConversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user             User                   @relation(fields: [userId], references: [id], onDelete: Restrict)
  workOrder        WorkOrder?             @relation(fields: [workOrderId], references: [id])
  workOrderId      String?

  @@index([conversationId, createdAt])
}

model AssistantActionRequest {
  id               String                       @id @default(cuid())
  conversationId   String
  userId           String
  actionName       String
  status           AssistantActionRequestStatus @default(PENDING)
  targetEntityType DomainEntityType
  targetEntityId   String?
  title            String
  summary          String
  payloadJson      Json
  decisionNote     String?
  createdAt        DateTime                     @default(now())
  updatedAt        DateTime                     @updatedAt
  conversation     AssistantConversation        @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user             User                         @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([conversationId, status, createdAt])
  @@index([userId, status, createdAt])
}

model WhatsAppMessage {
  id                String                    @id @default(cuid())
  providerMessageId String?                   @unique
  direction         WhatsAppDirection
  senderPhone       String?
  receiverPhone     String?
  body              String
  linkedEntityType  DomainEntityType          @default(UNKNOWN)
  linkedEntityId    String?
  detectedActorType WhatsAppDetectedActorType @default(UNKNOWN)
  processedStatus   WhatsAppProcessedStatus   @default(PENDING)
  processingNote    String?
  linkedUserId      String?
  channelIdentityId String?
  createdAt         DateTime                  @default(now())
  linkedUser        User?                     @relation("WhatsAppMessageLinkedUser", fields: [linkedUserId], references: [id], onDelete: SetNull)
  channelIdentity   UserChannelIdentity?      @relation(fields: [channelIdentityId], references: [id], onDelete: SetNull)

  @@index([processedStatus, createdAt])
  @@index([linkedEntityType, linkedEntityId])
  @@index([linkedUserId, createdAt])
  @@index([channelIdentityId, createdAt])
}

model UserChannelIdentity {
  id              String                @id @default(cuid())
  userId          String
  channel         MessagingChannel
  externalAddress String
  status          ChannelIdentityStatus @default(VERIFIED)
  verifiedAt      DateTime?
  revokedAt       DateTime?
  lastIncomingAt  DateTime?
  lastOutgoingAt  DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  user            User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages        WhatsAppMessage[]

  @@unique([channel, externalAddress])
  @@index([userId, channel, status])
}

model ChannelPairingSession {
  id              String                      @id @default(cuid())
  userId          String
  channel         MessagingChannel
  pairingCodeHash String
  status          ChannelPairingSessionStatus @default(PENDING)
  expiresAt       DateTime
  consumedAt      DateTime?
  revokedAt       DateTime?
  attemptCount    Int                         @default(0)
  createdAt       DateTime                    @default(now())
  updatedAt       DateTime                    @updatedAt
  user            User                        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, channel, status, expiresAt])
  @@index([channel, pairingCodeHash, status])
}

model ManualAction {
  id                String             @id @default(cuid())
  actionType        ManualActionType
  relatedEntityType DomainEntityType
  relatedEntityId   String?
  title             String
  description       String?
  dueAt             DateTime?
  createdByUserId   String
  assignedUserId    String?
  status            ManualActionStatus @default(OPEN)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  workOrderId       String?
  createdBy         User               @relation("ManualActionCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  assignedUser      User?              @relation("ManualActionAssignee", fields: [assignedUserId], references: [id], onDelete: SetNull)
  workOrder         WorkOrder?         @relation(fields: [workOrderId], references: [id], onDelete: SetNull)

  @@index([status, dueAt])
  @@index([relatedEntityType, relatedEntityId])
}

model AuditLog {
  id                    String           @id @default(cuid())
  actorUserId           String?
  actorUserNameSnapshot String?
  actorSource           AuditActorSource
  entityType            DomainEntityType
  entityId              String?
  eventName             String
  beforeJson            Json?
  afterJson             Json?
  createdAt             DateTime         @default(now())
  actorUser             User?            @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId, createdAt])
  @@index([actorUserId, createdAt])
}

model HeartbeatConfig {
  id                 String               @id @default(cuid())
  scope              String               @unique @default("global")
  enabled            Boolean              @default(false)
  cadenceValue       Int                  @default(30)
  cadenceUnit        HeartbeatCadenceUnit @default(MINUTES)
  cadenceMinutes     Int                  @default(30)
  lastRunAt          DateTime?
  lastCursorAt       DateTime?
  lastDeliveryAt     DateTime?
  lastRunStatus      HeartbeatRunStatus   @default(IDLE)
  lastRunSummary     String?
  lastError          String?
  updatedByUserId    String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  updatedBy          User?                @relation("HeartbeatConfigUpdater", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  notifications      HeartbeatNotification[]
}

model HeartbeatNotification {
  id              String           @id @default(cuid())
  configId        String
  dedupeKey       String           @unique
  auditLogId      String?
  recipientUserId String
  channel         MessagingChannel?
  payload         String
  delivered       Boolean          @default(false)
  reason          String?
  attemptCount    Int              @default(1)
  lastAttemptAt   DateTime         @default(now())
  deliveredAt     DateTime?
  createdAt       DateTime         @default(now())
  config          HeartbeatConfig  @relation(fields: [configId], references: [id], onDelete: Cascade)
  recipientUser   User             @relation("HeartbeatNotificationRecipient", fields: [recipientUserId], references: [id], onDelete: Cascade)

  @@index([configId, createdAt])
  @@index([recipientUserId, createdAt])
  @@index([auditLogId, createdAt])
}
